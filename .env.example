# AI_HEADER
# module: M-DEPLOY-ENV
# wave: W-DEPLOY
# purpose: Environment variables template for production deployment

# Astro — root .env.example
# ---------------------------------------------------------------
# Canonical env-var spec defined in W-DEPLOY.
# Per-service overrides still live in apps/api/.env.example etc.
# ---------------------------------------------------------------

# --- App ---
APP_ENV=production
APP_DOMAIN=astro.example.com
APP_VERSION=0.1.0
CONTRACT_VERSION=1

# --- Database (Postgres for production) ---
DATABASE_URL=postgresql+asyncpg://astro:${DB_PASSWORD}@db:5432/astro
POSTGRES_USER=astro
POSTGRES_PASSWORD=changeme
POSTGRES_DB=astro
DB_PASSWORD=changeme

# --- Redis ---
REDIS_URL=redis://127.0.0.1:6379/0

# --- SolarSage (external service, runs in its own docker) ---
# We only consume it over HTTP. Do NOT add SOLARSAGE_* runtime vars here —
# those belong to the SolarSage repo / its own compose file.
SOLARSAGE_BASE_URL=http://solarsage:8001
SOLARSAGE_API_KEY=

# --- Frontend (Vite) ---
VITE_API_URL=https://${APP_DOMAIN}/api

# --- Auth / secrets (placeholders, generate per-environment) ---
JWT_SECRET=change-me-in-real-env

# --- Observability (canon §8.4 — referenced from W-1.6 onward) ---
# Server-only salt used to derive non-reversible user_id_hash for log
# correlation. NEVER ship to the frontend. Rotate -> all historical
# logs become un-joinable, which is intended on incident.
GRACE_USER_SALT=change-me-32-bytes-min
# Per-service debug toggle, off in prod by canon §8.3.
GRACE_LOG_DEBUG=0

# --- W-1.7: Log shipping ---
# Kill-switch for browser->backend log shipping. Default off in dev, on in prod.
NEXT_PUBLIC_GRACE_LOG_SHIPPING=true

# --- LLM / Telegram / etc. ---
TELEGRAM_BOT_TOKEN=your_bot_token
OPENAI_API_KEY=your_openai_key
