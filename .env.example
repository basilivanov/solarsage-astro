# Astro — root .env.example (dev-loop convenience)
# ---------------------------------------------------------------
# This is NOT the canonical env-var spec. The single source of
# truth will be defined in W-DEPLOY (see grace/development-plan.xml).
# Per-service overrides still live in apps/api/.env.example etc.
# ---------------------------------------------------------------

# --- App ---
APP_ENV=dev
APP_DOMAIN=localhost
APP_VERSION=0.1.0
CONTRACT_VERSION=1

# --- Database (Postgres for full dev; SQLite is the bootstrap.sh default) ---
# For docker-compose dev stack:
DATABASE_URL=postgresql+asyncpg://astro:astro@127.0.0.1:5432/astro
POSTGRES_USER=astro
POSTGRES_PASSWORD=astro
POSTGRES_DB=astro

# --- Redis ---
REDIS_URL=redis://127.0.0.1:6379/0

# --- SolarSage (external service, runs in its own docker) ---
# We only consume it over HTTP. Do NOT add SOLARSAGE_* runtime vars here —
# those belong to the SolarSage repo / its own compose file.
SOLARSAGE_BASE_URL=http://127.0.0.1:8080
SOLARSAGE_API_KEY=

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000
NEXT_PUBLIC_USE_FIXTURES=1

# --- Auth / secrets (placeholders, generate per-environment) ---
JWT_SECRET=change-me-in-real-env

# --- Observability (canon §8.4 — referenced from W-1.6 onward) ---
# Server-only salt used to derive non-reversible user_id_hash for log
# correlation. NEVER ship to the frontend. Rotate -> all historical
# logs become un-joinable, which is intended on incident.
GRACE_USER_SALT=change-me-32-bytes-min
# Per-service debug toggle, off in prod by canon §8.3.
GRACE_LOG_DEBUG=0
# W-1.7 kill-switch for browser->backend log shipping. off until W-1.7 lands.
GRACE_LOG_SHIPPING=off

# --- LLM / Telegram / etc. ---
# Added by the wave that first reads them. Do not invent keys here.
