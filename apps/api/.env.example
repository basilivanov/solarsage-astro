# W-1.1 minimum env. Feature-specific vars (telegram, solarsage, llm)
# are added by the wave that first reads them.

APP_ENV=dev
APP_DOMAIN=localhost
APP_VERSION=0.1.0

# Default SQLite for local dev so `alembic upgrade head` works out of the box.
# In production set to a Postgres URL using +asyncpg driver, e.g.:
# DATABASE_URL=postgresql+asyncpg://astro:astro@127.0.0.1:5432/astro
DATABASE_URL=sqlite+aiosqlite:///./astro_dev.db

CONTRACT_VERSION=1

# --- Telegram WebApp auth (W-1.2) ---
# HMAC secret seed; absent/empty in dev means "skip HMAC" (test-only bypass).
TELEGRAM_BOT_TOKEN=
# Reject payloads older than this (seconds). Default: 24h per ## Decision.
INITDATA_MAX_AGE_SECONDS=86400

# --- Server-side session (W-1.2 Option A) ---
SESSION_COOKIE_NAME=grace_session
SESSION_TTL_SECONDS=2592000
# Set to false ONLY in local dev over plain HTTP. Telegram WebApp is HTTPS.
SESSION_COOKIE_SECURE=true
